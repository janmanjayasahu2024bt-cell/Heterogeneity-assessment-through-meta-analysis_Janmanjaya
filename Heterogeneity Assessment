classify_gene <- function(df) {
  
  if(nrow(df) < 2) return(data.frame())
  
  model <- tryCatch(
    rma(yi = df$logFC, vi = df$vi, method = "REML"),
    error = function(e) return(NULL)
  )
  
  if(is.null(model)) return(data.frame())
  
  res <- rstandard(model)$z
  
  df$status <- ifelse(abs(res) > 2,
                      "Heterogeneous",
                      "Homogeneous")
  
  df
}

