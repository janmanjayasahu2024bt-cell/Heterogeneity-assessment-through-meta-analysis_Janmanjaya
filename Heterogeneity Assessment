# -----------------------------
# Function to compute effect size + variance
# -----------------------------
compute_effect <- function(eig, group) {
  
  group <- as.factor(group)
  
  case <- eig[group %in% c("Schizophrenia", "SCZ")]
  control <- eig[group %in% c("Control", "CNT")]
  
  m1 <- mean(case, na.rm = TRUE)
  m0 <- mean(control, na.rm = TRUE)
  
  v1 <- var(case, na.rm = TRUE)
  v0 <- var(control, na.rm = TRUE)
  
  n1 <- length(case)
  n0 <- length(control)
  
  # Effect size (mean difference)
  yi <- m1 - m0
  
  # Variance of mean difference
  vi <- (v1/n1) + (v0/n0)
  
  return(c(yi = yi, vi = vi))
}

