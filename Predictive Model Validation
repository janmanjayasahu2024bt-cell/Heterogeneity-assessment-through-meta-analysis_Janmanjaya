# =========================================================
# GENE SYMBOL STANDARDIZATION
# =========================================================

standardize_gene_symbols <- function(ds) {
  cat("\nStandardizing gene annotations...\n")
  current_ids <- rownames(ds)
  
  mapped_symbols <- mapIds(
    org.Hs.eg.db,
    keys = current_ids,
    column = "SYMBOL",
    keytype = "SYMBOL",
    multiVals = "first"
  )
  
  keep <- !is.na(mapped_symbols)
  ds_clean <- ds[keep, , drop = FALSE]
  rownames(ds_clean) <- mapped_symbols[keep]
  
  duplicate_counts <- table(rownames(ds_clean))
  ds_sum <- rowsum(ds_clean, group = rownames(ds_clean))
  ds_final <- ds_sum / as.numeric(duplicate_counts[rownames(ds_sum)])
  
  return(as.matrix(ds_final))
}

ds1 <- standardize_gene_symbols(ds1)
ds2 <- standardize_gene_symbols(ds2)
ds3 <- standardize_gene_symbols(ds3)
test_homo <- standardize_gene_symbols(test_homo)
