cat("\nConverting datasets to numeric matrices...\n")

convert_to_numeric_matrix <- function(ds) {
  original_colnames <- colnames(ds)
  original_rownames <- rownames(ds)
  ds <- as.data.frame(ds, check.names = FALSE)
  ds[] <- lapply(ds, function(x) as.numeric(as.character(x)))
  ds <- as.matrix(ds)
  mode(ds) <- "numeric"
  colnames(ds) <- original_colnames
  rownames(ds) <- original_rownames
  return(ds)
}

ds1 <- convert_to_numeric_matrix(ds1)
ds2 <- convert_to_numeric_matrix(ds2)
ds3 <- convert_to_numeric_matrix(ds3)
