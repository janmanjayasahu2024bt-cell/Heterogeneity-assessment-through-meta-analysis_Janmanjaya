cat("\nFinding common training genes...\n")
common_genes <- Reduce(intersect, list(rownames(ds1), rownames(ds2), rownames(ds3)))
cat("\nNumber of common genes:", length(common_genes), "\n")

ds1 <- ds1[common_genes, , drop = FALSE]
ds2 <- ds2[common_genes, , drop = FALSE]
ds3 <- ds3[common_genes, , drop = FALSE]

cat("\nMerging training datasets...\n")
train_merged <- cbind(ds1, ds2, ds3)

# =========================================================
# INVERSE LOG2 TRANSFORMATION ON TRAIN
# =========================================================

cat("\nApplying Inverse Log2 transformation (2^x) to Training data...\n")
train_merged <- 2^train_merged

# =========================================================
# LOAD AND ALIGN METADATA
# =========================================================

cat("\nLoading metadata...\n")
pheno <- read.csv("merged_pheno_data.csv", stringsAsFactors = FALSE)

pheno_train <- pheno[match(colnames(train_merged), pheno$GSM_ID), ]
alignment_check <- all(colnames(train_merged) == pheno_train$GSM_ID)
if(!alignment_check) stop("Metadata mismatch detected!")

group <- factor(pheno_train$Diagnosis)
batch <- factor(pheno_train$GSE_ID)

# =========================================================
# PCA BEFORE COMBAT (TRAIN DISPERSION QC)
# =========================================================

cat("\nGenerating PCA BEFORE ComBat...\n")
pca_before <- prcomp(t(train_merged), scale. = TRUE)
plot(pca_before$x[,1], pca_before$x[,2], col = batch, pch = 19, xlab = "PC1", ylab = "PC2", main = "TRAIN PCA BEFORE ComBat")
legend("topright", legend = levels(batch), col = 1:length(levels(batch)), pch = 19)

# =========================================================
# COMBAT CORRECTION - TRAIN DATA ONLY
# =========================================================

cat("\nRunning ComBat on Training Data...\n")
modcombat <- model.matrix(~ group)
combat_train <- ComBat(
  dat = as.matrix(train_merged),
  batch = batch,
  mod = modcombat,
  par.prior = TRUE,
  prior.plots = FALSE
)

# =========================================================
# PCA AFTER COMBAT (TRAIN HOMOGENIZATION QC)
# =========================================================

cat("\nGenerating PCA AFTER ComBat...\n")
pca_after <- prcomp(t(combat_train), scale. = TRUE)
plot(pca_after$x[,1], pca_after$x[,2], col = batch, pch = 19, xlab = "PC1", ylab = "PC2", main = "TRAIN PCA AFTER ComBat")
legend("topright", legend = levels(batch), col = 1:length(levels(batch)), pch = 19)

# =========================================================
# LIMMA FEATURE RANKING & BUILD TRAINING MATRIX
# =========================================================

cat("\nRunning Limma feature ranking...\n")
design <- model.matrix(~ group)
fit <- lmFit(combat_train, design)
fit <- eBayes(fit)
deg_table <- topTable(fit, coef = 2, number = Inf, adjust.method = "BH")

selected_genes <- rownames(combat_train)

train_matrix <- t(combat_train[selected_genes, , drop = FALSE])
non_zero_var <- apply(train_matrix, 2, sd) != 0
train_matrix <- train_matrix[, non_zero_var, drop = FALSE]
selected_genes <- colnames(train_matrix)

train_df <- data.frame(Diagnosis = group, train_matrix)

# =========================================================
# TRAIN SVM MODEL (GROUND TRUTH)
# =========================================================

cat("\nTraining SVM model on Ground Truth Train...\n")
set.seed(123)
svm_model <- svm(
  Diagnosis ~ .,
  data = train_df,
  kernel = "linear",
  probability = TRUE
)
cat("SVM training complete.\n")

# =========================================================
# FUNCTION: MOLD TEST DATA TO TRAIN & GENERATE PCA QC
# =========================================================

align_test_combat <- function(test_data, train_reference, selected_genes, dataset_name = "TEST") {
  
  cat("\n====================================\n")
  cat("Aligning & Molding:", dataset_name, "via ComBat ref.batch\n")
  cat("====================================\n")
  
  test_data <- 2^test_data
  
  test_data <- test_data[rownames(test_data) %in% selected_genes, , drop = FALSE]
  
  missing_genes <- setdiff(selected_genes, rownames(test_data))
  
  if(length(missing_genes) > 0) {
    
    imputed_values <- apply(
      train_reference[missing_genes, , drop = FALSE],
      1,
      median,
      na.rm = TRUE
    )
    
    missing_matrix <- matrix(
      rep(imputed_values, ncol(test_data)),
      nrow = length(missing_genes),
      dimnames = list(
        missing_genes,
        colnames(test_data)
      )
    )
    
    test_data <- rbind(test_data, missing_matrix)
  }
  
  test_data <- test_data[selected_genes, , drop = FALSE]
  
  combined_dat <- cbind(
    train_reference[selected_genes, , drop = FALSE],
    test_data
  )
  
  batch_vec <- c(
    rep("Train_Anchor", ncol(train_reference)),
    rep("Incoming_Test", ncol(test_data))
  )
  
  # =====================================================
  # PCA BEFORE COMBAT
  # =====================================================
  
  pca_test_before <- prcomp(
    t(combined_dat),
    scale. = TRUE
  )
  
  plot(
    pca_test_before$x[,1],
    pca_test_before$x[,2],
    col = factor(batch_vec),
    pch = c(19,17)[factor(batch_vec)],
    xlab = "PC1",
    ylab = "PC2",
    cex = 1.2,
    main = paste(dataset_name, "PCA BEFORE Ref-ComBat")
  )
  
  # =====================================================
  # RUN COMBAT
  # =====================================================
  
  cat("Running ComBat (ref.batch = Train_Anchor)...\n")
  
  combat_res <- ComBat(
    dat = combined_dat,
    batch = factor(batch_vec),
    ref.batch = "Train_Anchor",
    par.prior = TRUE
  )
  
  # =====================================================
  # PCA AFTER COMBAT
  # =====================================================
  
  pca_test_after <- prcomp(
    t(combat_res),
    scale. = TRUE
  )
  
  plot(
    pca_test_after$x[,1],
    pca_test_after$x[,2],
    col = factor(batch_vec),
    pch = c(19,17)[factor(batch_vec)],
    xlab = "PC1",
    ylab = "PC2",
    cex = 1.2,
    main = paste(dataset_name, "PCA AFTER Ref-ComBat")
  )
  
  # =====================================================
  # RETURN TEST DATA ONLY
  # =====================================================
  
  test_molded <- combat_res[
    ,
    (ncol(train_reference) + 1):ncol(combined_dat)
  ]
  
  df_molded <- as.data.frame(t(test_molded))
  
  colnames(df_molded) <- make.names(colnames(df_molded))
  
  return(df_molded)
}

